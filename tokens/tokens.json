{
  "meta": {
    "name": "Carine Petry — Editorial Medical Design System",
    "version": "2.0.0",
    "source": "Brandbook oficial + direção editorial premium",
    "principles": [
      "Composição antes de ornamento. Hierarquia antes de efeito.",
      "Magenta é ação, não decoração — máximo ~5% da superfície visual.",
      "Serifada em display, citação e número. Sans em tudo que é funcional.",
      "Cor sólida, linha fina e respiro no lugar de gradiente e sombra."
    ]
  },

  "color": {
    "brand": {
      "borgonha-dark":    { "value": "#241021", "usage": "Fundo institucional sólido. Hero, CTA final, rodapé." },
      "borgonha":         { "value": "#4A1942", "usage": "Títulos, elementos de autoridade, numeração editorial." },
      "vinho":            { "value": "#6B2A55", "usage": "Detalhe editorial, hover em superfície escura." },
      "rosa-queimado":    { "value": "#A8577A", "usage": "Kicker e detalhe sobre fundo escuro." },
      "magenta":          { "value": "#8E1348", "usage": "Link e acento em texto. Contraste 7.9:1 sobre creme." },
      "magenta-acao":     { "value": "#B01755", "usage": "Ação primária apenas. Uso restrito." },
      "magenta-acao-hover": { "value": "#8E1348", "usage": "Hover da ação primária." }
    },
    "neutral": {
      "creme":        { "value": "#FBF7F4", "usage": "Fundo principal. Quente e neutro, sem viés rosado." },
      "creme-fundo":  { "value": "#F4EEE9", "usage": "Seção alternada e superfície de repouso." },
      "branco":       { "value": "#FFFFFF", "usage": "Superfície pontual. Nunca como card repetido." },
      "linha":        { "value": "#E2DAD3", "usage": "Divisores e bordas de 1px, baixo contraste." },
      "linha-forte":  { "value": "#CBBFB6", "usage": "Borda de ênfase e estado de foco em campo." },
      "grafite-claro":{ "value": "#7A716B", "usage": "Metadados, legendas, texto de apoio. 4.9:1 sobre creme." },
      "grafite":      { "value": "#3A3532", "usage": "Corpo de texto. Contraste 11.2:1 sobre creme — AAA." },
      "tinta":        { "value": "#1C1917", "usage": "Máximo contraste. Títulos técnicos." }
    },
    "onDark": {
      "texto":     { "value": "#F0E7E2", "usage": "Corpo de texto sobre borgonha. 12.1:1 — AAA." },
      "texto-fraco": { "value": "#C9B4BF", "usage": "Apoio sobre borgonha. 6.4:1 — AA." },
      "linha":     { "value": "rgba(240,231,226,0.16)", "usage": "Divisor sobre fundo escuro." }
    },
    "semantic": {
      "sucesso":       { "value": "#1D6E4F", "usage": "Estado de sucesso em formulário." },
      "sucesso-bg":    { "value": "#EAF3EF", "usage": "Fundo do estado de sucesso." },
      "erro":          { "value": "#A62B22", "usage": "Validação e estado de erro. 6.1:1 sobre creme." },
      "erro-bg":       { "value": "#FBEDEC", "usage": "Fundo do estado de erro." },
      "aviso-bg":      { "value": "#F7F1E6", "usage": "Fundo de aviso médico." }
    }
  },

  "typography": {
    "family": {
      "display": { "value": "'Cormorant Garamond', 'Iowan Old Style', Georgia, serif", "usage": "Display, títulos de seção, citação, numeração. Nunca em UI funcional." },
      "body":    { "value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif", "usage": "Navegação, corpo, cards, dados, botões, formulários." }
    },
    "scale": {
      "display-xl": { "family": "display", "size": "clamp(2.75rem, 5.4vw, 4.75rem)", "weight": 500, "lineHeight": 1.02, "tracking": "-0.022em", "usage": "Hero da home. 44px mobile → 76px desktop." },
      "display-l":  { "family": "display", "size": "clamp(2.5rem, 4.6vw, 4rem)",     "weight": 500, "lineHeight": 1.05, "tracking": "-0.02em",  "usage": "H1 de página interna. 40 → 64px." },
      "display-m":  { "family": "display", "size": "clamp(2rem, 3.4vw, 3rem)",       "weight": 500, "lineHeight": 1.1,  "tracking": "-0.015em", "usage": "H2 de seção editorial. 32 → 48px." },
      "display-s":  { "family": "display", "size": "clamp(1.65rem, 2.4vw, 2.375rem)","weight": 500, "lineHeight": 1.15, "tracking": "-0.01em",  "usage": "H2 secundário. 26 → 38px." },
      "heading":    { "family": "body",    "size": "clamp(1.25rem, 1.6vw, 1.5rem)",  "weight": 500, "lineHeight": 1.3,  "tracking": "-0.008em", "usage": "H3 funcional em sans. 20 → 24px." },
      "heading-serif": { "family": "display", "size": "clamp(1.375rem, 1.9vw, 1.75rem)", "weight": 500, "lineHeight": 1.25, "tracking": "0", "usage": "H3 editorial em serifada. 22 → 28px." },
      "lead":       { "family": "body",    "size": "clamp(1.0625rem, 1.15vw, 1.1875rem)", "weight": 400, "lineHeight": 1.62, "tracking": "0", "usage": "Parágrafo de abertura. 17 → 19px." },
      "body":       { "family": "body",    "size": "1.0625rem",                      "weight": 400, "lineHeight": 1.68, "tracking": "0",       "usage": "Corpo padrão. 17px." },
      "body-sm":    { "family": "body",    "size": "0.9375rem",                      "weight": 400, "lineHeight": 1.6,  "tracking": "0",       "usage": "Texto secundário. 15px." },
      "caption":    { "family": "body",    "size": "0.875rem",                       "weight": 400, "lineHeight": 1.5,  "tracking": "0",       "usage": "Metadados e legendas. 14px." },
      "micro":      { "family": "body",    "size": "0.8125rem",                      "weight": 500, "lineHeight": 1.4,  "tracking": "0.1em",   "usage": "Kicker e rótulo em caixa alta. 13px — mínimo do sistema." },
      "numeral":    { "family": "display", "size": "clamp(2.25rem, 3vw, 3.25rem)",   "weight": 500, "lineHeight": 1,    "tracking": "-0.01em", "usage": "Numeração editorial de etapas." }
    },
    "measure": {
      "prose": "66ch",
      "lead": "58ch",
      "display": "17ch"
    }
  },

  "space": {
    "base": "8px",
    "scale": {
      "3xs": "2px", "2xs": "4px", "xs": "8px", "sm": "12px", "md": "16px",
      "lg": "24px", "xl": "32px", "2xl": "48px", "3xl": "72px", "4xl": "104px", "5xl": "144px"
    },
    "section": { "mobile": "64px", "tablet": "88px", "desktop": "128px" }
  },

  "radius": {
    "none": "0", "xs": "4px", "sm": "8px", "md": "12px", "pill": "999px"
  },

  "layout": {
    "container": "1280px",
    "container-wide": "1440px",
    "container-prose": "680px",
    "grid-columns": 12,
    "gutter": "24px",
    "gutter-desktop": "32px",
    "margin-mobile": "20px",
    "margin-desktop": "48px",
    "header-height": "84px",
    "header-height-mobile": "64px"
  },

  "breakpoint": {
    "xs": "390px", "sm": "480px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1440px"
  },

  "elevation": {
    "subtle": { "value": "0 1px 2px rgba(36, 16, 33, 0.04)", "usage": "Elevação mínima. Uso raro." },
    "header": { "value": "0 1px 0 rgba(36, 16, 33, 0.07)", "usage": "Header ao rolar — linha, não sombra." },
    "sheet":  { "value": "0 0 0 100vmax rgba(28, 25, 23, 0.45)", "usage": "Overlay do drawer mobile." }
  },

  "motion": {
    "duration": { "fast": "160ms", "base": "280ms", "slow": "440ms" },
    "easing": {
      "out":    "cubic-bezier(0.22, 1, 0.36, 1)",
      "in-out": "cubic-bezier(0.65, 0, 0.35, 1)"
    },
    "reveal": { "offset": "14px", "duration": "440ms", "stagger": "70ms" },
    "principles": [
      "Apenas transform e opacity.",
      "Deslocamento de entrada entre 12 e 16px. Nunca escala nem rotação.",
      "Stagger só em grupos de até 4 elementos.",
      "Tudo desligado sob prefers-reduced-motion."
    ]
  },

  "a11y": {
    "touch-target-min": "44px",
    "focus-ring": "0 0 0 2px #FBF7F4, 0 0 0 4px #B01755",
    "contrast-target": "AAA no corpo de texto, AA em todo o resto. Verificado por cálculo, não por estimativa."
  }
}
