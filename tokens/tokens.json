{
  "$schema": "https://design-tokens.org/schema.json",
  "meta": {
    "name": "Carine Petry Medical Design System",
    "version": "1.0.0",
    "source": "Brandbook Oficial — Dra. Carine Petry",
    "description": "Fonte única de verdade do ecossistema digital. Todo módulo (site, landing pages, área do paciente, materiais ricos) consome estes tokens."
  },

  "color": {
    "brand": {
      "borgonha-dark":    { "value": "#2D0F28", "usage": "Fundos profundos, rodapé, gradiente de hero" },
      "borgonha":         { "value": "#4A1942", "usage": "Cor primária. Títulos, faixas de destaque, marca" },
      "magenta":          { "value": "#9D174D", "usage": "Cor de ação. Links, acentos" },
      "magenta-dark":     { "value": "#7D1450", "usage": "Estado hover de ação, fim do gradiente" },
      "magenta-vibrante": { "value": "#C41E62", "usage": "CTA primário. Uso restrito para preservar impacto" },
      "rosa-suave":       { "value": "#E9B8CF", "usage": "Texto de apoio sobre fundo escuro, kickers" },
      "rosa-claro":       { "value": "#F3DCE8", "usage": "Corpo de texto sobre fundo escuro" }
    },
    "neutral": {
      "creme":        { "value": "#FFF9FB", "usage": "Fundo padrão da página" },
      "branco":       { "value": "#FFFFFF", "usage": "Superfície de card e seção alternada" },
      "cinza-claro":  { "value": "#E5E5E5", "usage": "Bordas e divisores" },
      "cinza-medio":  { "value": "#9E9E9E", "usage": "Metadados, legendas, texto desabilitado" },
      "cinza-escuro": { "value": "#4A4A4A", "usage": "Corpo de texto. Contraste 8.6:1 sobre creme (AAA)" },
      "preto":        { "value": "#1A1A1A", "usage": "Texto de máximo contraste" }
    },
    "surface": {
      "rodape-texto":  { "value": "#D8C3D2", "usage": "Corpo de texto do rodapé sobre borgonha escuro" },
      "rodape-legal":  { "value": "#A98DA3", "usage": "Linha legal do rodapé" }
    },
    "semantic": {
      "sucesso": { "value": "#1D9E75", "usage": "Confirmação de formulário, estado de sucesso" },
      "sucesso-texto": { "value": "#0F6E56", "usage": "Texto sobre fundo de sucesso. Contraste 5.2:1" },
      "erro":    { "value": "#C0392B", "usage": "Validação de formulário, estado de erro" },
      "aviso":   { "value": "#BA7517", "usage": "Alertas e avisos médicos" },
      "info":    { "value": "#185FA5", "usage": "Notas informativas e disclaimers" }
    },
    "contrast-notes": {
      "cinza-escuro-sobre-creme": "8.6:1 — AAA",
      "borgonha-sobre-creme": "12.4:1 — AAA",
      "magenta-sobre-creme": "6.8:1 — AA large + AA normal",
      "branco-sobre-borgonha": "12.4:1 — AAA",
      "branco-sobre-magenta-vibrante": "5.1:1 — AA"
    }
  },

  "typography": {
    "family": {
      "display": { "value": "'Cormorant Garamond', Georgia, serif", "usage": "Títulos, citações, números de destaque" },
      "body":    { "value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "usage": "Corpo, interface, formulários" }
    },
    "scale": {
      "display-xl": { "family": "display", "size": "clamp(2.6rem, 6vw, 4.2rem)",   "weight": 600, "lineHeight": 1.05, "tracking": "-0.02em", "usage": "Hero de landing page" },
      "display-l":  { "family": "display", "size": "clamp(2.1rem, 5.5vw, 3.4rem)", "weight": 600, "lineHeight": 1.15, "tracking": "-0.01em", "usage": "Hero da home" },
      "display-m":  { "family": "display", "size": "clamp(1.8rem, 4vw, 2.6rem)",   "weight": 600, "lineHeight": 1.2,  "tracking": "0",       "usage": "Citação de manifesto" },
      "h1":         { "family": "display", "size": "clamp(1.9rem, 4.5vw, 2.8rem)", "weight": 600, "lineHeight": 1.2,  "tracking": "0",       "usage": "Título de página e artigo" },
      "h2":         { "family": "display", "size": "clamp(1.6rem, 3.5vw, 2.2rem)", "weight": 600, "lineHeight": 1.25, "tracking": "0",       "usage": "Título de seção" },
      "h3":         { "family": "display", "size": "1.3rem",                       "weight": 600, "lineHeight": 1.3,  "tracking": "0",       "usage": "Título de card e subseção" },
      "body":       { "family": "body",    "size": "1rem",                         "weight": 400, "lineHeight": 1.7,  "tracking": "0",       "usage": "Texto padrão" },
      "body-lead":  { "family": "body",    "size": "1.08rem",                      "weight": 400, "lineHeight": 1.7,  "tracking": "0",       "usage": "Parágrafo de abertura de seção" },
      "caption":    { "family": "body",    "size": "0.88rem",                      "weight": 400, "lineHeight": 1.6,  "tracking": "0",       "usage": "Legendas, metadados, disclaimer" },
      "micro":      { "family": "body",    "size": "0.72rem",                      "weight": 600, "lineHeight": 1.4,  "tracking": "0.14em",  "usage": "Kicker e rótulo em caixa alta" }
    }
  },

  "space": {
    "base": "8px",
    "scale": {
      "2xs": "4px", "xs": "8px", "sm": "12px", "md": "16px",
      "lg": "24px", "xl": "32px", "2xl": "48px", "3xl": "72px", "4xl": "112px"
    },
    "section": { "mobile": "48px", "tablet": "64px", "desktop": "88px" }
  },

  "radius": {
    "sm": "8px", "md": "12px", "lg": "16px", "pill": "999px"
  },

  "layout": {
    "container": "1080px",
    "container-narrow": "720px",
    "grid-columns": 12,
    "gutter": "24px"
  },

  "breakpoint": {
    "sm": "480px", "md": "768px", "lg": "1024px", "xl": "1280px"
  },

  "elevation": {
    "card":  { "value": "0 10px 30px rgba(74, 25, 66, 0.08)", "usage": "Hover de card" },
    "cta":   { "value": "0 6px 20px rgba(196, 30, 98, 0.35)", "usage": "CTA primário" },
    "float": { "value": "0 -2px 16px rgba(45, 15, 40, 0.12)", "usage": "Barra de CTA fixa no mobile" }
  },

  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "360ms" },
    "easing": {
      "out":       "cubic-bezier(0.22, 1, 0.36, 1)",
      "in-out":    "cubic-bezier(0.65, 0, 0.35, 1)",
      "overshoot": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "principles": [
      "Movimento serve à compreensão, nunca à decoração.",
      "Elementos entram com 12px de deslocamento e fade — nunca escala ou rotação.",
      "Toda animação respeita prefers-reduced-motion."
    ]
  },

  "a11y": {
    "touch-target-min": "44px",
    "focus-ring": "0 0 0 3px rgba(196, 30, 98, 0.35)",
    "contrast-target": "WCAG AA para todo texto; AAA para corpo de texto"
  }
}
